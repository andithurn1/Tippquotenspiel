# ── Tippquotenspiel — Umgebungsvariablen ────────────────────
# Kopiere diese Datei nach `.env.local` und trage deine Werte ein.
# `.env.local` ist in .gitignore und landet NIE im Repo.
#
# Ohne diese Werte läuft die App automatisch auf dem In-Memory-Mock
# (src/lib/store.mock.js) — praktisch für Entwicklung ohne Backend.

# Supabase-Projekt → Settings → API
# URL + anon-Key sind fürs Frontend gedacht (durch Row Level Security
# geschützt), deshalb NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role-Key NUR serverseitig (API-Routen, Jobs). NIEMALS
# NEXT_PUBLIC_ voranstellen — sonst landet er im Browser-Bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Später (Roadmap Punkt 6): echter Quoten-API-Key — ebenfalls nur
# serverseitig, wird über eine Next.js-API-Route geproxyt.
# ODDS_API_KEY=
